# .env.example
# Copy this file to .env before running docker-compose

# Backend Configuration
ENVIRONMENT=production
API_V1_STR=/api/v1
PROJECT_NAME="Audiobook Video Maker"

# Redis Queue Connection
# In Docker, 'redis' is the service name
REDIS_URL=redis://redis:6379/0

# Storage Paths (inside the containers, these are mounted to the host)
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
TEMP_DIR=/app/temp

# Frontend Configuration
# This tells the frontend where to make API requests
VITE_API_URL=/api/v1
